# Configuração da LLM
# Este arquivo é apenas um exemplo.
# Nunca coloque chaves reais aqui.

# Opções suportadas:
# mock      -> simula a LLM
# disabled  -> usa apenas heurísticas
# openai    -> usa API real da OpenAI
LLM_PROVIDER=mock

# Para mock:
LLM_MODEL=mock-model

# Para OpenAI, exemplo:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.5

# Chave da API.
# Use apenas no arquivo .env local ou em variável de ambiente.
LLM_API_KEY=

# Alternativamente, o SDK da OpenAI também reconhece:
# OPENAI_API_KEY=